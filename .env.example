# Application
APP_NAME=taskforge
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL (used by API and future worker)
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=taskforge
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://taskforge:change-me-in-production@postgres:5432/taskforge

# Optional: override for pytest (defaults to localhost with docker-compose credentials)
# TEST_DATABASE_URL=postgresql+asyncpg://taskforge:taskforge@localhost:5432/taskforge

# Redis (task queue — wired in Phase 2)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_KEY=taskforge:tasks:queue
WORKER_BRPOP_TIMEOUT=5
TASK_RETRY_QUEUE_KEY=taskforge:tasks:retry
RETRY_BACKOFF_BASE_SECONDS=1
RETRY_BACKOFF_MAX_SECONDS=300
TASK_DLQ_KEY=taskforge:tasks:dlq
WORKER_HEARTBEAT_KEY=taskforge:worker:heartbeat
WORKER_HEARTBEAT_TTL_SECONDS=60

# Auth (JWT for POST /api/v1/tasks)
JWT_SECRET_KEY=change-me-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-auth-password

# Rate limiting (slowapi)
RATE_LIMIT_ENABLED=true
RATE_LIMIT=30/minute
